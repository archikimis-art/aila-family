n    \"signUp\": \"Sign up\"\r\n  },\r\n  \"seoPages\": {\r\n    \"beginner\": {\r\n      \"metaTitle\": \"Genealogy for Beginners: Where to Start? 2025 Guide | AILA\",\r\n      \"metaDescription\": \"New to genealogy? Discover where to start your research. Complete beginner's guide: methods, free tools, expert tips.\",\r\n      \"badge\": \"🎓 Beginner's Guide • 2025\",\r\n      \"title\": \"Genealogy for Beginners: Where to Start?\",\r\n      \"subtitle\": \"Want to discover your family history but don't know where to start? This guide walks you through your first genealogical research step by step.\",\r\n      \"summaryTitle\": \"💡 In brief: Where to start with genealogy?\",\r\n      \"summaryText\": \"1. Interview your family and collect existing documents\\n2. Create your tree with what you already know\\n3. Check online departmental archives (free)\\n4. Go back generation by generation, without skipping steps\",\r\n      \"step1\": {\r\n        \"title\": \"Step 1: Start with Yourself\",\r\n        \"text\": \"Genealogy always starts with yourself. Write down your full name, date and place of birth. Then work backwards gradually.\",\r\n        \"tipTitle\": \"🎯 Golden rule\",\r\n        \"tipText\": \"Never skip a generation! Each ancestor must be verified before moving on to the next.\"\r\n      },\r\n      \"step2\": {\r\n        \"title\": \"Step 2: Interview Your Family\",\r\n        \"text\": \"Your parents, grandparents, uncles and aunts are treasure troves of information. Prepare a list of questions and record their answers.\",\r\n        \"check1\": \"✅ Names of ancestors\",\r\n        \"check2\": \"✅ Important dates (birth, marriage, death)\",\r\n        \"check3\": \"✅ Places of residence\",\r\n        \"check4\": \"✅ Professions\",\r\n        \"check5\": \"✅ Family anecdotes\"\r\n      },\r\n      \"step3\": {\r\n        \"title\": \"Step 3: Create Your Tree\",\r\n        \"text\": \"A family tree allows you to visualize your research and identify gaps to fill. Use a digital tool like AILA to easily organize your discoveries.\"\r\n      },\r\n      \"step4\": {\r\n        \"title\": \"Step 4: Online Archives\",\r\n        \"text\": \"Departmental archives are digitized and freely accessible. You'll find civil registry records, censuses and much more.\",\r\n        \"resourceTitle\": \"🏛️ Free resources\",\r\n        \"resource1\": \"• Regional departmental archives\",\r\n        \"resource2\": \"• FamilySearch.org - Free worldwide database\",\r\n        \"resource3\": \"• Geneanet.org - French-speaking community\",\r\n        \"resource4\": \"• Ancestry.com - Large database (partial free)\"\r\n      },\r\n      \"errors\": {\r\n        \"title\": \"5 Beginner Mistakes\",\r\n        \"error1\": { \"title\": \"❌ 1. Going too fast\", \"desc\": \"Take time to verify each piece of information.\" },\r\n        \"error2\": { \"title\": \"❌ 2. Not noting sources\", \"desc\": \"Where does this info come from? Note it systematically.\" },\r\n        \"error3\": { \"title\": \"❌ 3. Confusing namesakes\", \"desc\": \"John Smith, there are thousands! Verify.\" },\r\n        \"error4\": { \"title\": \"❌ 4. Copying online trees\", \"desc\": \"They often contain errors. Verify with sources.\" },\r\n        \"error5\": { \"title\": \"❌ 5. Neglecting collaterals\", \"desc\": \"Siblings can reveal information about your ancestors.\" }\r\n      },\r\n      \"cta\": {\r\n        \"title\": \"🌳 Ready to Start?\",\r\n        \"text\": \"Create your free family tree with AILA and start your journey into family history.\",\r\n        \"button\": \"Create My Free Tree\"\r\n      }\r\n    },\r\n    \"ancestors\": {\r\n      \"metaTitle\": \"How to Find Your Ancestors for Free: Complete 2025 Guide | AILA\",\r\n      \"metaDescription\": \"Discover how to find your ancestors for free in 2025. Complete guide with online archives, civil records, research methods and free tools.\",\r\n      \"badge\": \"📚 Expert Guide • January 2025\",\r\n      \"title\": \"How to Find Your Ancestors for Free\",\r\n      \"subtitle\": \"The complete guide to starting your genealogical research without spending a dime. Methods, resources and free tools tested by our team.\",\r\n      \"authorName\": \"Written by the AILA team\",\r\n      \"authorCredentials\": \"Genealogy experts • 10+ years experience\",\r\n      \"authorDate\": \"Last updated: January 2025\",\r\n      \"tocTitle\": \"📑 Contents\",\r\n      \"toc\": {\r\n        \"item1\": \"1. Where to start your research?\",\r\n        \"item2\": \"2. Free online archives\",\r\n        \"item3\": \"3. Civil registry records\",\r\n        \"item4\": \"4. Genealogical databases\",\r\n        \"item5\": \"5. Step-by-step method\",\r\n        \"item6\": \"6. Mistakes to avoid\",\r\n        \"item7\": \"7. FAQ\"\r\n      },\r\n      \"summaryTitle\": \"💡 In brief: How to find your ancestors for free?\",\r\n      \"summaryText\": \"To find your ancestors for free, start by interviewing your family, then check online departmental archives (civil records, censuses). Use free tools like FamilySearch or Geneanet to expand your research. Organize everything in a digital family tree like AILA.\",\r\n      \"section1\": {\r\n        \"title\": \"1. Where to Start Your Genealogical Research?\",\r\n        \"intro\": \"Before diving into archives, the first step is often the simplest and richest: talking to your family.\",\r\n        \"tipTitle\": \"🎯 Expert tip\",\r\n        \"tipText\": \"ALWAYS start with what you know. Write down the names, dates, and places you already know. Each piece of information is a thread to pull.\",\r\n        \"checklistTitle\": \"Priority information to collect:\",\r\n        \"check1\": \"✅ Full names (including maiden names)\",\r\n        \"check2\": \"✅ Birth, marriage, death dates\",\r\n        \"check3\": \"✅ Locations (town, region)\",\r\n        \"check4\": \"✅ Professions\",\r\n        \"check5\": \"✅ Family anecdotes and stories\",\r\n        \"check6\": \"✅ Old photos with names on the back\",\r\n        \"outro\": \"Don't forget to search through drawers! Family record books, announcements, old letters... These documents are gold mines.\"\r\n      },\r\n      \"section2\": {\r\n        \"title\": \"2. Free Online Departmental Archives\",\r\n        \"intro\": \"Good news: almost all French departmental archives are digitized and freely accessible online. This is THE essential resource for any genealogist.\",\r\n        \"cardTitle\": \"What you'll find there\",\r\n        \"card1\": \"• Parish registers (before 1792)\",\r\n        \"card2\": \"• Civil status (births, marriages, deaths)\",\r\n        \"card3\": \"• Population censuses\",\r\n        \"card4\": \"• Military matriculation registers\",\r\n        \"card5\": \"• Ten-year tables\",\r\n        \"card6\": \"• Cadastres and old maps\",\r\n        \"accessTitle\": \"How to access your department's archives?\",\r\n        \"accessText\": \"Search \\\"departmental archives + [department name]\\\" on Google, or check the France Archives portal which lists all sites.\",\r\n        \"warningTitle\": \"⚠️ Warning\",\r\n        \"warningText\": \"Records less than 75 years old (births) or 25 years (marriages/deaths) are generally not online for privacy reasons.\"\r\n      },\r\n      \"section3\": {\r\n        \"title\": \"3. Civil Registry Records: How-To Guide\",\r\n        \"intro\": \"Civil registry records have been kept in duplicate since 1792: one at the town hall, one at the departmental archives.\",\r\n        \"methodTitle\": \"The ten-year tables method\",\r\n        \"methodText\": \"Ten-year tables are indexes that summarize all records over 10 years. They're your best friend for quickly finding a record!\",\r\n        \"step1\": \"Identify the municipality and approximate period\",\r\n        \"step2\": \"Check the corresponding ten-year table\",\r\n        \"step3\": \"Find the name and note the exact year\",\r\n        \"step4\": \"Access the register for that year\",\r\n        \"step5\": \"Read the complete record and note the information\"\r\n      },\r\n      \"section4\": {\r\n        \"title\": \"4. Free Genealogical Databases\",\r\n        \"intro\": \"In addition to official archives, several community sites offer valuable resources for free.\",\r\n        \"resource1\": {\r\n          \"name\": \"🌍 FamilySearch.org\",\r\n          \"desc\": \"The largest free database in the world. Billions of digitized documents and shared family trees. 100% free.\",\r\n          \"pros\": \"✅ Free • Huge database • International\"\r\n        },\r\n        \"resource2\": {\r\n          \"name\": \"🇫🇷 Geneanet.org\",\r\n          \"desc\": \"The French leader. Generous free version with access to shared trees and many collaborative databases.\",\r\n          \"pros\": \"✅ In French • Active community • Shared trees\"\r\n        },\r\n        \"resource3\": {\r\n          \"name\": \"📋 Filae.com\",\r\n          \"desc\": \"Limited free access but useful for civil status records. Paid version for full archive access.\",\r\n          \"pros\": \"✅ Indexed records • Easy search\"\r\n        },\r\n        \"resource4\": {\r\n          \"name\": \"⚔️ Mémoire des Hommes\",\r\n          \"desc\": \"Official site of the Ministry of Armed Forces. Files of soldiers who died for France, war diaries, military registers.\",\r\n          \"pros\": \"✅ 100% free • Official • Detailed\"\r\n        }\r\n      },\r\n      \"section5\": {\r\n        \"title\": \"5. Step by Step: Your First Month of Research\",\r\n        \"week1\": {\r\n          \"label\": \"Week 1\",\r\n          \"title\": \"Family collection\",\r\n          \"desc\": \"Interview parents, grandparents, uncles, aunts. Photograph all documents. Create your tree with what you know.\"\r\n        },\r\n        \"week2\": {\r\n          \"label\": \"Week 2\",\r\n          \"title\": \"Online archives\",\r\n          \"desc\": \"Identify municipalities of origin. Access departmental archives. Search for your grandparents' records.\"\r\n        },\r\n        \"week3\": {\r\n          \"label\": \"Week 3\",\r\n          \"title\": \"Going back generations\",\r\n          \"desc\": \"Use information from records to go back. Marriage records often mention the parents of the spouses.\"\r\n        },\r\n        \"week4\": {\r\n          \"label\": \"Week 4\",\r\n          \"title\": \"Consolidation\",\r\n          \"desc\": \"Verify your sources. Complete your tree. Identify 'brick walls' to explore later.\"\r\n        }\r\n      },\r\n      \"section6\": {\r\n        \"title\": \"6. The 7 Mistakes to Avoid in Genealogy\",\r\n        \"error1\": { \"title\": \"Not citing sources\", \"desc\": \"ALWAYS note where each piece of information comes from. In 6 months, you won't remember.\" },\r\n        \"error2\": { \"title\": \"Confusing namesakes\", \"desc\": \"John Smith born in 1850, there are dozens! Always cross-reference multiple sources.\" },\r\n        \"error3\": { \"title\": \"Trusting online trees\", \"desc\": \"Shared trees often contain copied errors. Verify with original sources.\" },\r\n        \"error4\": { \"title\": \"Ignoring collaterals\", \"desc\": \"Brothers, sisters, uncles... Their records may contain info about your ancestors.\" },\r\n        \"error5\": { \"title\": \"Forgetting name variations\", \"desc\": \"Smith, Smyth, Smithe... Spelling varied greatly. Think phonetically!\" },\r\n        \"error6\": { \"title\": \"Neglecting historical context\", \"desc\": \"Wars, epidemics, migrations... Understanding context helps explain gaps.\" },\r\n        \"error7\": { \"title\": \"Wanting to go too fast\", \"desc\": \"Genealogy is a marathon, not a sprint. Take time to document properly.\" }\r\n      },\r\n      \"faq\": {\r\n        \"title\": \"7. Frequently Asked Questions\",\r\n        \"q1\": \"How far back can you go for free?\",\r\n        \"a1\": \"In France, parish registers generally start in the 16th century (1539). With patience, you can go back 15-20 generations for free via departmental archives.\",\r\n        \"q2\": \"How long does it take to find your ancestors?\",\r\n        \"a2\": \"Count a few hours for great-grandparents, a few days for the 18th century, and several months/years for complete genealogy over 10+ generations.\",\r\n        \"q3\": \"Do you need to read old French?\",\r\n        \"a3\": \"For recent documents (after 1800), no. For older registers, paleography is learned gradually. Free guides exist online.\",\r\n        \"q4\": \"How to organize all this information?\",\r\n        \"a4\": \"Use family tree software or an app like AILA. This allows you to centralize information and easily visualize your tree.\"\r\n      },\r\n      \"cta\": {\r\n        \"title\": \"🌳 Ready to Find Your Ancestors?\",\r\n        \"text\": \"Create your free family tree with AILA and organize all your discoveries. Share with your family and preserve your history.\",\r\n        \"button\": \"Create My Free Tree\"\r\n      }\r\n    },\r\n    \"traditions\": {\r\n      \"metaTitle\": \"Family Traditions: 50 Ideas to Create and Perpetuate Your Own | AILA\",\r\n      \"metaDescription\": \"Discover 50+ family tradition ideas to create or perpetuate. Daily rituals, celebrations, meals, trips. Strengthen family bonds.\",\r\n      \"badge\": \"🎄 Family Life • 2025 Guide\",\r\n      \"title\": \"Family Traditions: 50 Ideas to Create Unforgettable Memories\",\r\n      \"subtitle\": \"Family traditions are the glue that binds generations together. Discover how to create, perpetuate and pass on these precious moments that define your family.\"\r\n    },\r\n    \"cousinade\": {\r\n      \"metaTitle\": \"How to Organize a Family Reunion: Complete Guide + Checklist | AILA\",\r\n      \"metaDescription\": \"Organize a successful family reunion! Complete guide: planning, budget, invitations, activities, meals. Free checklist to gather the whole family.\",\r\n      \"badge\": \"🎉 Family Reunion\",\r\n      \"title\": \"How to Organize a Successful Family Reunion\",\r\n      \"subtitle\": \"A family reunion is the perfect opportunity to bring the whole family together. Here's the complete guide to organizing it from A to Z.\",\r\n      \"checklistTitle\": \"📋 Quick Checklist\",\r\n      \"checklist\": \"✓ Set a date 6 months in advance\\n✓ Create a list of all members\\n✓ Choose a suitable venue\\n✓ Send invitations 3 months before\\n✓ Organize activities and meals\\n✓ Plan photos and souvenirs\",\r\n      \"step1\": {\r\n        \"title\": \"📅 Step 1: Planning (6 months before)\",\r\n        \"task1\": { \"title\": \"Choose the date\", \"desc\": \"Prefer a summer weekend or holiday. Avoid school vacations if you want to maximize participation.\" },\r\n        \"task2\": { \"title\": \"Create the organizing committee\", \"desc\": \"Form a team of 3-5 people from different branches. Distribute responsibilities.\" },\r\n        \"task3\": { \"title\": \"List all members\", \"desc\": \"Use your AILA family tree to get the complete list. Don't forget anyone!\" }\r\n      },\r\n      \"step2\": {\r\n        \"title\": \"📍 Step 2: Choose the Venue\",\r\n        \"option1\": { \"title\": \"At a member's home\", \"pros\": \"✅ Free, intimate, practical\", \"cons\": \"❌ Limited capacity\" },\r\n        \"option2\": { \"title\": \"Cottage or campsite\", \"pros\": \"✅ Large capacity, weekend possible\", \"cons\": \"❌ Cost, advance booking\" },\r\n        \"option3\": { \"title\": \"Community hall\", \"pros\": \"✅ Equipped, spacious\", \"cons\": \"❌ May lack charm\" }\r\n      },\r\n      \"step3\": {\r\n        \"title\": \"💰 Step 3: Budget Guide\",\r\n        \"budget1\": { \"label\": \"Venue rental\", \"amount\": \"$0 - $500\" },\r\n        \"budget2\": { \"label\": \"Meals (per person)\", \"amount\": \"$10 - $25\" },\r\n        \"budget3\": { \"label\": \"Activities\", \"amount\": \"$50 - $200\" },\r\n        \"budget4\": { \"label\": \"Photos/Souvenirs\", \"amount\": \"$30 - $100\" },\r\n        \"tipTitle\": \"💡 Budget tip\",\r\n        \"tipText\": \"Ask for a contribution per family rather than per person. Potluck format for meals = guaranteed savings!\"\r\n      },\r\n      \"step4\": {\r\n        \"title\": \"🎯 Step 4: Must-Have Activities\",\r\n        \"activity1\": \"Group photo\",\r\n        \"activity2\": \"Tree presentation\",\r\n        \"activity3\": \"Intergenerational games\",\r\n        \"activity4\": \"Family quiz\",\r\n        \"activity5\": \"Story sharing\",\r\n        \"activity6\": \"Sports tournament\"\r\n      },\r\n      \"cta\": {\r\n        \"title\": \"🌳 Ready to Organize Your Family Reunion?\",\r\n        \"text\": \"Create your AILA family tree to identify all your family members and never forget anyone!\",\r\n        \"button\": \"Create My Free Tree\"\r\n      }\r\n    }\r\n  }\r\n}\r\n;\n});","lineCount":1305,"map":[[1305,3]],"functionMap":null},"type":"js/module"}]}