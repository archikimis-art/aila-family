ionRequired\": \"Accesso richiesto\",\r\n    \"createAccountPrompt\": \"Crea un account gratuito per partecipare alle sfide e guadagnare distintivi!\",\r\n    \"later\": \"Più tardi\",\r\n    \"signUp\": \"Registrati\"\r\n  },\r\n  \"seoPages\": {\r\n    \"beginner\": {\r\n      \"metaTitle\": \"Genealogia per Principianti: Da Dove Iniziare? Guida 2025 | AILA\",\r\n      \"metaDescription\": \"Nuovo nella genealogia? Scopri da dove iniziare la tua ricerca. Guida completa per principianti: metodo, strumenti gratuiti, consigli di esperti.\",\r\n      \"badge\": \"🎓 Guida per Principianti • 2025\",\r\n      \"title\": \"Genealogia per Principianti: Da Dove Iniziare?\",\r\n      \"subtitle\": \"Vuoi scoprire la storia della tua famiglia ma non sai da dove cominciare? Questa guida ti accompagna passo dopo passo nelle tue prime ricerche genealogiche.\",\r\n      \"summaryTitle\": \"💡 In breve: Da dove iniziare la genealogia?\",\r\n      \"summaryText\": \"1. Intervista la tua famiglia e raccogli i documenti esistenti\\n2. Crea il tuo albero con quello che già sai\\n3. Consulta gli archivi dipartimentali online (gratis)\\n4. Risali generazione per generazione, senza saltare passaggi\",\r\n      \"step1\": {\r\n        \"title\": \"Passo 1: Inizia da Te Stesso\",\r\n        \"text\": \"La genealogia inizia sempre da se stessi. Annota il tuo nome completo, data e luogo di nascita. Poi risali gradualmente.\",\r\n        \"tipTitle\": \"🎯 Regola d'oro\",\r\n        \"tipText\": \"Non saltare mai una generazione! Ogni antenato deve essere verificato prima di passare al successivo.\"\r\n      },\r\n      \"step2\": {\r\n        \"title\": \"Passo 2: Intervista la Tua Famiglia\",\r\n        \"text\": \"I tuoi genitori, nonni, zii e zie sono tesori di informazioni. Prepara una lista di domande e registra le loro risposte.\",\r\n        \"check1\": \"✅ Nomi degli antenati\",\r\n        \"check2\": \"✅ Date importanti (nascita, matrimonio, morte)\",\r\n        \"check3\": \"✅ Luoghi di residenza\",\r\n        \"check4\": \"✅ Professioni\",\r\n        \"check5\": \"✅ Aneddoti familiari\"\r\n      },\r\n      \"step3\": {\r\n        \"title\": \"Passo 3: Crea il Tuo Albero\",\r\n        \"text\": \"Un albero genealogico ti permette di visualizzare le tue ricerche e identificare i vuoti da riempire. Usa uno strumento digitale come AILA per organizzare facilmente le tue scoperte.\"\r\n      },\r\n      \"step4\": {\r\n        \"title\": \"Passo 4: Gli Archivi Online\",\r\n        \"text\": \"Gli archivi dipartimentali sono digitalizzati e accessibili gratuitamente. Troverai registri di stato civile, censimenti e molto altro.\",\r\n        \"resourceTitle\": \"🏛️ Risorse gratuite\",\r\n        \"resource1\": \"• Archivi dipartimentali di ogni regione\",\r\n        \"resource2\": \"• FamilySearch.org - Database mondiale gratuito\",\r\n        \"resource3\": \"• Geneanet.org - Comunità francofona\",\r\n        \"resource4\": \"• Archivi Militari\"\r\n      },\r\n      \"errors\": {\r\n        \"title\": \"I 5 Errori del Principiante\",\r\n        \"error1\": { \"title\": \"❌ 1. Voler andare troppo veloce\", \"desc\": \"Prenditi il tempo di verificare ogni informazione.\" },\r\n        \"error2\": { \"title\": \"❌ 2. Non annotare le fonti\", \"desc\": \"Da dove viene questa info? Annotalo sistematicamente.\" },\r\n        \"error3\": { \"title\": \"❌ 3. Confondere gli omonimi\", \"desc\": \"Marco Rossi, ce ne sono migliaia! Verifica.\" },\r\n        \"error4\": { \"title\": \"❌ 4. Copiare alberi online\", \"desc\": \"Spesso contengono errori. Verifica alle fonti.\" },\r\n        \"error5\": { \"title\": \"❌ 5. Trascurare i collaterali\", \"desc\": \"Fratelli e sorelle possono rivelare informazioni sui tuoi antenati.\" }\r\n      },\r\n      \"cta\": {\r\n        \"title\": \"🌳 Pronto per Iniziare?\",\r\n        \"text\": \"Crea il tuo albero genealogico gratuito con AILA e inizia il tuo viaggio nella storia familiare.\",\r\n        \"button\": \"Crea il Mio Albero Gratis\"\r\n      }\r\n    },\r\n    \"ancestors\": {\r\n      \"metaTitle\": \"Come Trovare i Tuoi Antenati Gratis: Guida Completa 2025 | AILA\",\r\n      \"metaDescription\": \"Scopri come trovare i tuoi antenati gratis nel 2025. Guida completa con archivi online, registri civili, metodi di ricerca e strumenti gratuiti.\",\r\n      \"badge\": \"📚 Guida Esperta • Gennaio 2025\",\r\n      \"title\": \"Come Trovare i Tuoi Antenati Gratis\",\r\n      \"subtitle\": \"La guida completa per iniziare la tua ricerca genealogica senza spendere un centesimo. Metodi, risorse e strumenti gratuiti testati dal nostro team.\",\r\n      \"authorName\": \"Scritto dal team AILA\",\r\n      \"authorCredentials\": \"Esperti di genealogia • 10+ anni di esperienza\",\r\n      \"authorDate\": \"Ultimo aggiornamento: Gennaio 2025\",\r\n      \"tocTitle\": \"📑 Indice\",\r\n      \"toc\": {\r\n        \"item1\": \"1. Da dove iniziare?\",\r\n        \"item2\": \"2. Archivi online gratuiti\",\r\n        \"item3\": \"3. Registri di stato civile\",\r\n        \"item4\": \"4. Database genealogici\",\r\n        \"item5\": \"5. Metodo passo per passo\",\r\n        \"item6\": \"6. Errori da evitare\",\r\n        \"item7\": \"7. FAQ\"\r\n      },\r\n      \"summaryTitle\": \"💡 In breve: Come trovare i tuoi antenati gratis?\",\r\n      \"summaryText\": \"Per trovare i tuoi antenati gratis, inizia intervistando la tua famiglia, poi consulta gli archivi dipartimentali online. Usa strumenti gratuiti come FamilySearch o Geneanet. Organizza tutto in un albero genealogico digitale come AILA.\",\r\n      \"section1\": {\r\n        \"title\": \"1. Da Dove Iniziare la Tua Ricerca?\",\r\n        \"intro\": \"Prima di immergerti negli archivi, il primo passo è spesso il più semplice: parlare con la tua famiglia.\",\r\n        \"tipTitle\": \"🎯 Consiglio dell'esperto\",\r\n        \"tipText\": \"Inizia SEMPRE con quello che sai. Annota nomi, date e luoghi che già conosci.\",\r\n        \"checklistTitle\": \"Informazioni prioritarie da raccogliere:\",\r\n        \"check1\": \"✅ Nomi completi (inclusi cognomi da nubile)\",\r\n        \"check2\": \"✅ Date di nascita, matrimonio, morte\",\r\n        \"check3\": \"✅ Luoghi (comune, regione)\",\r\n        \"check4\": \"✅ Professioni\",\r\n        \"check5\": \"✅ Aneddoti familiari\",\r\n        \"check6\": \"✅ Vecchie foto con nomi sul retro\",\r\n        \"outro\": \"Non dimenticare di cercare nei cassetti! Libretti di famiglia, partecipazioni, lettere antiche...\"\r\n      },\r\n      \"section2\": {\r\n        \"title\": \"2. Archivi Dipartimentali Online (100% Gratis)\",\r\n        \"intro\": \"Buone notizie: quasi tutti gli archivi dipartimentali francesi sono digitalizzati e accessibili gratuitamente online.\",\r\n        \"cardTitle\": \"Cosa troverai\",\r\n        \"card1\": \"• Registri parrocchiali (prima del 1792)\",\r\n        \"card2\": \"• Stato civile (nascite, matrimoni, morti)\",\r\n        \"card3\": \"• Censimenti\",\r\n        \"card4\": \"• Registri militari\",\r\n        \"card5\": \"• Tavole decennali\",\r\n        \"card6\": \"• Catasti e mappe antiche\",\r\n        \"accessTitle\": \"Come accedere agli archivi del tuo dipartimento?\",\r\n        \"accessText\": \"Cerca \\\"archivi dipartimentali + [nome dipartimento]\\\" su Google.\",\r\n        \"warningTitle\": \"⚠️ Attenzione\",\r\n        \"warningText\": \"I registri di meno di 75 anni (nascite) o 25 anni (matrimoni/morti) generalmente non sono online per privacy.\"\r\n      },\r\n      \"section3\": {\r\n        \"title\": \"3. Registri di Stato Civile: Guida all'Uso\",\r\n        \"intro\": \"I registri di stato civile sono tenuti in duplice copia dal 1792.\",\r\n        \"methodTitle\": \"Il metodo delle tavole decennali\",\r\n        \"methodText\": \"Le tavole decennali sono indici che riassumono tutti gli atti in 10 anni. Il tuo miglior alleato!\",\r\n        \"step1\": \"Identifica il comune e il periodo approssimativo\",\r\n        \"step2\": \"Consulta la tavola decennale corrispondente\",\r\n        \"step3\": \"Trova il nome e annota l'anno esatto\",\r\n        \"step4\": \"Accedi al registro di quell'anno\",\r\n        \"step5\": \"Leggi l'atto completo e annota le informazioni\"\r\n      },\r\n      \"section4\": {\r\n        \"title\": \"4. Database Genealogici Gratuiti\",\r\n        \"intro\": \"Oltre agli archivi ufficiali, diversi siti comunitari offrono risorse preziose gratuitamente.\",\r\n        \"resource1\": { \"name\": \"🌍 FamilySearch.org\", \"desc\": \"Il più grande database gratuito al mondo. Miliardi di documenti.\", \"pros\": \"✅ Gratuito • Database enorme • Internazionale\" },\r\n        \"resource2\": { \"name\": \"🇫🇷 Geneanet.org\", \"desc\": \"Il leader francese. Versione gratuita generosa.\", \"pros\": \"✅ In francese • Comunità attiva\" },\r\n        \"resource3\": { \"name\": \"📋 Filae.com\", \"desc\": \"Accesso gratuito limitato ma utile per registri civili.\", \"pros\": \"✅ Registri indicizzati • Ricerca facile\" },\r\n        \"resource4\": { \"name\": \"⚔️ Mémoire des Hommes\", \"desc\": \"Sito ufficiale del Ministero delle Forze Armate.\", \"pros\": \"✅ 100% gratuito • Ufficiale\" }\r\n      },\r\n      \"section5\": {\r\n        \"title\": \"5. Passo Dopo Passo: Il Tuo Primo Mese\",\r\n        \"week1\": { \"label\": \"Settimana 1\", \"title\": \"Raccolta familiare\", \"desc\": \"Intervista genitori, nonni, zii. Fotografa tutti i documenti.\" },\r\n        \"week2\": { \"label\": \"Settimana 2\", \"title\": \"Archivi online\", \"desc\": \"Identifica i comuni di origine. Accedi agli archivi dipartimentali.\" },\r\n        \"week3\": { \"label\": \"Settimana 3\", \"title\": \"Risalire generazioni\", \"desc\": \"Usa le informazioni degli atti per risalire.\" },\r\n        \"week4\": { \"label\": \"Settimana 4\", \"title\": \"Consolidamento\", \"desc\": \"Verifica le tue fonti. Completa il tuo albero.\" }\r\n      },\r\n      \"section6\": {\r\n        \"title\": \"6. I 7 Errori da Evitare\",\r\n        \"error1\": { \"title\": \"Non citare le fonti\", \"desc\": \"Annota SEMPRE da dove viene ogni informazione.\" },\r\n        \"error2\": { \"title\": \"Confondere omonimi\", \"desc\": \"Marco Rossi nato nel 1850, ce ne sono decine!\" },\r\n        \"error3\": { \"title\": \"Fidarsi degli alberi online\", \"desc\": \"Spesso contengono errori copiati.\" },\r\n        \"error4\": { \"title\": \"Ignorare i collaterali\", \"desc\": \"Fratelli possono rivelare info sui tuoi antenati.\" },\r\n        \"error5\": { \"title\": \"Dimenticare variazioni di nomi\", \"desc\": \"L'ortografia variava molto. Pensa foneticamente!\" },\r\n        \"error6\": { \"title\": \"Ignorare il contesto storico\", \"desc\": \"Guerre, epidemie... aiutano a spiegare i vuoti.\" },\r\n        \"error7\": { \"title\": \"Voler andare troppo veloce\", \"desc\": \"La genealogia è una maratona, non uno sprint.\" }\r\n      },\r\n      \"faq\": {\r\n        \"title\": \"7. Domande Frequenti\",\r\n        \"q1\": \"Quanto indietro si può andare gratis?\",\r\n        \"a1\": \"In Francia, i registri parrocchiali iniziano nel XVI secolo. Puoi risalire 15-20 generazioni gratis.\",\r\n        \"q2\": \"Quanto tempo serve per trovare antenati?\",\r\n        \"a2\": \"Qualche ora per bisnonni, qualche giorno per il XVIII secolo, diversi mesi per genealogia completa.\",\r\n        \"q3\": \"Bisogna saper leggere il francese antico?\",\r\n        \"a3\": \"Per documenti recenti (dopo il 1800) no. Per registri più antichi si impara gradualmente.\",\r\n        \"q4\": \"Come organizzare tutte queste informazioni?\",\r\n        \"a4\": \"Usa un software di albero genealogico come AILA.\"\r\n      },\r\n      \"cta\": {\r\n        \"title\": \"🌳 Pronto a Trovare i Tuoi Antenati?\",\r\n        \"text\": \"Crea il tuo albero genealogico gratis con AILA e organizza tutte le tue scoperte.\",\r\n        \"button\": \"Crea il Mio Albero Gratis\"\r\n      }\r\n    },\r\n    \"traditions\": {\r\n      \"metaTitle\": \"Tradizioni Familiari: 50 Idee per Creare e Perpetuare le Tue | AILA\",\r\n      \"metaDescription\": \"Scopri 50+ idee di tradizioni familiari da creare o perpetuare. Rituali quotidiani, celebrazioni, pasti, viaggi. Rafforza i legami familiari.\",\r\n      \"badge\": \"🎄 Vita Familiare • Guida 2025\",\r\n      \"title\": \"Tradizioni Familiari: 50 Idee per Creare Ricordi Indimenticabili\",\r\n      \"subtitle\": \"Le tradizioni familiari sono il cemento che unisce le generazioni. Scopri come creare, perpetuare e trasmettere questi momenti preziosi.\"\r\n    },\r\n    \"cousinade\": {\r\n      \"metaTitle\": \"Come Organizzare una Riunione di Famiglia: Guida Completa + Checklist | AILA\",\r\n      \"metaDescription\": \"Organizza una riunione di famiglia di successo! Guida completa: pianificazione, budget, inviti, attività, pasti.\",\r\n      \"badge\": \"🎉 Riunione di Famiglia\",\r\n      \"title\": \"Come Organizzare una Riunione di Famiglia di Successo\",\r\n      \"subtitle\": \"Una riunione di famiglia è l'occasione perfetta per riunire tutta la famiglia. Ecco la guida completa per organizzarla dalla A alla Z.\",\r\n      \"checklistTitle\": \"📋 Checklist rapida\",\r\n      \"checklist\": \"✓ Definire data 6 mesi prima\\n✓ Creare lista di tutti i membri\\n✓ Scegliere luogo adatto\\n✓ Inviare inviti 3 mesi prima\\n✓ Organizzare attività e pasti\\n✓ Prevedere foto e ricordi\",\r\n      \"step1\": {\r\n        \"title\": \"📅 Passo 1: Pianificazione (6 mesi prima)\",\r\n        \"task1\": { \"title\": \"Scegliere la data\", \"desc\": \"Preferisci un weekend estivo o festivo. Evita vacanze scolastiche per massimizzare la partecipazione.\" },\r\n        \"task2\": { \"title\": \"Creare il comitato organizzativo\", \"desc\": \"Forma un team di 3-5 persone da rami diversi. Distribuisci le responsabilità.\" },\r\n        \"task3\": { \"title\": \"Elencare tutti i membri\", \"desc\": \"Usa il tuo albero genealogico AILA per la lista completa. Non dimenticare nessuno!\" }\r\n      },\r\n      \"step2\": {\r\n        \"title\": \"📍 Passo 2: Scegliere il Luogo\",\r\n        \"option1\": { \"title\": \"A casa di un membro\", \"pros\": \"✅ Gratuito, intimo, pratico\", \"cons\": \"❌ Capacità limitata\" },\r\n        \"option2\": { \"title\": \"Agriturismo o campeggio\", \"pros\": \"✅ Grande capacità, weekend possibile\", \"cons\": \"❌ Costo, prenotazione anticipata\" },\r\n        \"option3\": { \"title\": \"Sala comunale\", \"pros\": \"✅ Attrezzata, spaziosa\", \"cons\": \"❌ Può mancare di fascino\" }\r\n      },\r\n      \"step3\": {\r\n        \"title\": \"💰 Passo 3: Budget Tipo\",\r\n        \"budget1\": { \"label\": \"Affitto luogo\", \"amount\": \"0€ - 500€\" },\r\n        \"budget2\": { \"label\": \"Pasti (a persona)\", \"amount\": \"10€ - 25€\" },\r\n        \"budget3\": { \"label\": \"Attività\", \"amount\": \"50€ - 200€\" },\r\n        \"budget4\": { \"label\": \"Foto/Ricordi\", \"amount\": \"30€ - 100€\" },\r\n        \"tipTitle\": \"💡 Consiglio budget\",\r\n        \"tipText\": \"Chiedi un contributo per famiglia invece che per persona. Formato potluck = risparmio garantito!\"\r\n      },\r\n      \"step4\": {\r\n        \"title\": \"🎯 Passo 4: Attività Imperdibili\",\r\n        \"activity1\": \"Foto di gruppo\",\r\n        \"activity2\": \"Presentazione albero\",\r\n        \"activity3\": \"Giochi intergenerazionali\",\r\n        \"activity4\": \"Quiz famiglia\",\r\n        \"activity5\": \"Condivisione storie\",\r\n        \"activity6\": \"Torneo sportivo\"\r\n      },\r\n      \"cta\": {\r\n        \"title\": \"🌳 Pronto a Organizzare la Tua Riunione?\",\r\n        \"text\": \"Crea il tuo albero genealogico AILA per identificare tutti i membri e non dimenticare nessuno!\",\r\n        \"button\": \"Crea il Mio Albero Gratis\"\r\n      }\r\n    }\r\n  }\r\n}\r\n;\n});","lineCount":1162,"map":[[1162,3]],"functionMap":null},"type":"js/module"}]}